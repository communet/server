{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "ts-node src/main.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db": "knex --knexfile ./knexfile.ts",
    "migration:make": "npm run db migrate:make",
    "migration:run": "npm run db migrate:latest",
    "migration:rollback": "npm run db migrate:rollback",
    "migration:up": "npm run db migrate:up",
    "migration:down": "npm run db migrate:down",
    "migration:list": "npm run db migrate:list",
    "seed:make": "npm run db seed:make",
    "seed:run": "npm run db seed:run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "dependencies": {
    "dotenv": "^17.0.1",
    "fastify": "^5.4.0",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "zod": "^3.25.75"
  }
}
