{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "tsx src/main.ts",
    "check:format": "prettier --check \"{src,test}/**/*.ts\"",
    "check:format:fix": "prettier --write \"{src,test}/**/*.ts\"",
    "check:lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "check:lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check:types": "tsc --noEmit",
    "check:types-lint-staged": "npm run check:types -- --module commonjs --emitDecoratorMetadata --experimentalDecorators --allowSyntheticDefaultImports --target esnext --strict --baseUrl ./ --skipLibCheck --strictNullChecks --forceConsistentCasingInFileNames --noImplicitAny --noFallthroughCasesInSwitch --strictBindCallApply",
    "check": "npm run check:lint && npm run check:types",
    "db": "node --import ts-node/esm ./node_modules/knex/bin/cli.js --knexfile ./knexfile.ts",
    "migration:make": "npm run db migrate:make",
    "migration:run": "npm run db migrate:latest",
    "migration:rollback": "npm run db migrate:rollback",
    "migration:up": "npm run db migrate:up",
    "migration:down": "npm run db migrate:down",
    "migration:list": "npm run db migrate:list",
    "seed:make": "npm run db seed:make",
    "seed:run": "npm run db seed:run",
    "test": "jest --runInBand",
    "test:core": "jest --testPathPatterns=src/core",
    "test:application": "jest --testPathPatterns=src/application",
    "test:infrastructure": "jest --runInBand --testPathPatterns=src/infrastructure",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9",
    "typescript-eslint": "^8.44.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "dotenv": "^17.0.1",
    "fastify": "^5.6.1",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.75"
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "npm run check:format",
      "npm run check:lint",
      "npm run check:types-lint-staged"
    ]
  }
}
